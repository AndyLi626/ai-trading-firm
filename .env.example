# Copy to .env for local development. Do not commit real credentials.

# GCP / BigQuery audit logging
GCP_PROJECT_ID=example-gcp-project
BIGQUERY_DATASET=trading_firm
GCP_SERVICE_ACCOUNT_FILE=C:/path/to/gcp-service-account.json

# Paper-trading credentials are loaded from ~/.openclaw/secrets by default.
# Keep real Alpaca keys out of git.
ALPACA_PAPER_KEY=replace-with-local-paper-key
ALPACA_PAPER_SECRET=replace-with-local-paper-secret

# Optional market-data provider keys for local experiments.
ALPHAVANTAGE_API_KEY=replace-with-local-key
FMP_API_KEY=replace-with-local-key
