{
  "table": "trading_firm.signal_outcomes",
  "description": "Signal outcome records for post-trade feedback loop and model calibration.",
  "ddl": "CREATE TABLE IF NOT EXISTS trading_firm.signal_outcomes (trade_plan_id STRING NOT NULL, symbol STRING NOT NULL, strategy STRING NOT NULL, fill_price FLOAT64 NOT NULL, dip_pct FLOAT64 NOT NULL, confidence FLOAT64 NOT NULL, volume_ratio FLOAT64, vix_at_entry FLOAT64, t1_price FLOAT64, t5_price FLOAT64, t15_price FLOAT64, t1_return FLOAT64, t5_return FLOAT64, t15_return FLOAT64, win_t5 BOOL, recorded_at TIMESTAMP NOT NULL) PARTITION BY DATE(recorded_at);",
  "fields": [
    {"name": "trade_plan_id", "type": "STRING", "nullable": false, "description": "Unique identifier for the trade plan."},
    {"name": "symbol", "type": "STRING", "nullable": false, "description": "Ticker symbol."},
    {"name": "strategy", "type": "STRING", "nullable": false, "description": "Strategy: mean_reversion | range_play | momentum."},
    {"name": "fill_price", "type": "FLOAT64", "nullable": false, "description": "Execution fill price."},
    {"name": "dip_pct", "type": "FLOAT64", "nullable": false, "description": "Dip % from reference at signal time."},
    {"name": "confidence", "type": "FLOAT64", "nullable": false, "description": "Model confidence score [0.0, 1.0]."},
    {"name": "volume_ratio", "type": "FLOAT64", "nullable": true, "description": "Volume at entry / 20-day avg volume."},
    {"name": "vix_at_entry", "type": "FLOAT64", "nullable": true, "description": "VIX level at entry."},
    {"name": "t1_price", "type": "FLOAT64", "nullable": true, "description": "Price 1 min after fill."},
    {"name": "t5_price", "type": "FLOAT64", "nullable": true, "description": "Price 5 min after fill."},
    {"name": "t15_price", "type": "FLOAT64", "nullable": true, "description": "Price 15 min after fill."},
    {"name": "t1_return", "type": "FLOAT64", "nullable": true, "description": "(t1_price - fill_price) / fill_price."},
    {"name": "t5_return", "type": "FLOAT64", "nullable": true, "description": "(t5_price - fill_price) / fill_price."},
    {"name": "t15_return", "type": "FLOAT64", "nullable": true, "description": "(t15_price - fill_price) / fill_price."},
    {"name": "win_t5", "type": "BOOL", "nullable": true, "description": "Primary label: true if t5_return > 0."},
    {"name": "recorded_at", "type": "TIMESTAMP", "nullable": false, "description": "UTC write timestamp."}
  ],
  "primary_label": "win_t5",
  "calibration_features": ["dip_pct", "confidence", "volume_ratio", "vix_at_entry"],
  "partition_by": "DATE(recorded_at)",
  "version": "1.0",
